{
  "components": {
    "schemas": {
      "ChoiceRequest": {
        "additionalProperties": false,
        "description": "Request payload for resolving a player choice.",
        "properties": {
          "choice_id": {
            "anyOf": [
              {
                "format": "uuid",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Choice Id"
          },
          "payload": {
            "title": "Payload"
          }
        },
        "title": "ChoiceRequest",
        "type": "object"
      },
      "DebugExprRequest": {
        "properties": {
          "expr": {
            "title": "Expr",
            "type": "string"
          },
          "node_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Node Id"
          }
        },
        "required": [
          "expr"
        ],
        "title": "DebugExprRequest",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "SystemInfo": {
        "properties": {
          "engine": {
            "title": "Engine",
            "type": "string"
          },
          "homepage_url": {
            "default": "https://github.com/derekmerck/storytangl",
            "format": "uri",
            "minLength": 1,
            "title": "Homepage Url",
            "type": "string"
          },
          "num_users": {
            "title": "Num Users",
            "type": "integer"
          },
          "uptime": {
            "title": "Uptime",
            "type": "string"
          },
          "version": {
            "title": "Version",
            "type": "string"
          },
          "worlds": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array"
              },
              {
                "type": "integer"
              }
            ],
            "title": "Worlds"
          }
        },
        "required": [
          "engine",
          "version",
          "uptime",
          "worlds",
          "num_users"
        ],
        "title": "SystemInfo",
        "type": "object"
      },
      "UserInfo": {
        "properties": {
          "achievements": {
            "anyOf": [
              {
                "items": {
                  "type": "string"
                },
                "type": "array",
                "uniqueItems": true
              },
              {
                "type": "null"
              }
            ],
            "title": "Achievements"
          },
          "created_dt": {
            "format": "date-time",
            "title": "Created Dt",
            "type": "string"
          },
          "last_played_dt": {
            "anyOf": [
              {
                "format": "date-time",
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Last Played Dt"
          },
          "stories_finished": {
            "default": 0,
            "title": "Stories Finished",
            "type": "integer"
          },
          "turns_played": {
            "default": 0,
            "title": "Turns Played",
            "type": "integer"
          },
          "user_id": {
            "format": "uuid",
            "title": "User Id",
            "type": "string"
          },
          "user_secret": {
            "title": "User Secret",
            "type": "string"
          },
          "worlds_played": {
            "items": {
              "type": "string"
            },
            "title": "Worlds Played",
            "type": "array",
            "uniqueItems": true
          }
        },
        "required": [
          "user_id",
          "user_secret",
          "created_dt",
          "worlds_played"
        ],
        "title": "UserInfo",
        "type": "object"
      },
      "UserSecret": {
        "maxItems": 3,
        "minItems": 2,
        "prefixItems": [
          {
            "title": "Api Key"
          },
          {
            "title": "User Secret"
          },
          {
            "title": "User Id"
          }
        ],
        "type": "array"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "contact": {
      "email": "tangldev@storytan.gl",
      "name": "TanglDev",
      "url": "https://github.com/derekmerck/storytangl"
    },
    "description": "RESTful endpoints for StoryTangl",
    "title": "StoryTangl",
    "version": "3.7.2"
  },
  "openapi": "3.1.0",
  "paths": {
    "/story/apply": {
      "post": {
        "description": "Apply a debug expression in the active story context.",
        "operationId": "apply_effect_post_story_apply_post",
        "parameters": [
          {
            "description": "Response rendering profile.",
            "in": "query",
            "name": "render_profile",
            "required": false,
            "schema": {
              "default": "raw",
              "description": "Response rendering profile.",
              "title": "Render Profile",
              "type": "string"
            }
          },
          {
            "example": "AXxngZiGzAqUJqMqzbMmtQ==",
            "in": "header",
            "name": "X-API-Key",
            "required": false,
            "schema": {
              "title": "X-Api-Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DebugExprRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "title": "Response Apply Effect Post Story Apply Post"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Apply Effect Post",
        "tags": [
          "Story",
          "Restricted"
        ]
      },
      "put": {
        "description": "Compatibility alias for :route:`POST /story/apply`.",
        "operationId": "apply_effect_put_story_apply_put",
        "parameters": [
          {
            "description": "Response rendering profile.",
            "in": "query",
            "name": "render_profile",
            "required": false,
            "schema": {
              "default": "raw",
              "description": "Response rendering profile.",
              "title": "Render Profile",
              "type": "string"
            }
          },
          {
            "example": "AXxngZiGzAqUJqMqzbMmtQ==",
            "in": "header",
            "name": "X-API-Key",
            "required": false,
            "schema": {
              "title": "X-Api-Key",
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/DebugExprRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "title": "Response Apply Effect Put Story Apply Put"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Apply Effect Put",
        "tags": [
          "Story",
          "Restricted"
        ]
      }
    },
