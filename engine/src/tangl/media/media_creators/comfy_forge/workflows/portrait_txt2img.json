    "_meta": {
      "title": "ksampler"
    }
  },
  "6": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "storytangl-portrait"
    },
    "_meta": {
      "title": "save_image"
    }
  }
